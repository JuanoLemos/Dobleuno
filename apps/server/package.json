{
  "name": "@dobleuno/server",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "runner": "tsx src/prompts/runner.ts",
    "prompts:eval": "tsx src/prompts/runner.ts --eval",
    "db:generate": "tsx ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "kb:seed": "tsx src/seed-kb-chunks.ts",
    "pgvector:install": "psql $DATABASE_URL -f src/db/migrations/0001_pgvector.sql"
  },
  "dependencies": {
    "@dobleuno/shared": "*",
    "better-auth": "^1.0.18",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "openai": "^4.71.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
