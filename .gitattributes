# Normalize line endings to LF (Unix-style)
# Saves files as LF in the repo, but checks out as native on Windows
* text=auto eol=lf

# Explicit for known binary types
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff2 binary
*.woff binary
*.ttf binary
*.eot binary

# Shell scripts must have LF
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files can have CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.mdc text eol=lf
